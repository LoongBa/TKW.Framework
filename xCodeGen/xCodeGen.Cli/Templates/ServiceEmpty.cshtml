@using System.Linq
@using xCodeGen.Abstractions
@using xCodeGen.Abstractions.Metadata
@using TKW.Framework.Domain.xCodeGen
@model xCodeGen.Abstractions.Metadata.ClassMetadata
@{
    var className = Model.ClassName;
    var serviceName = $"{className}Service";
    var genAttr = Model.Attributes.FirstOrDefault(a => a.TypeFullName.Contains("GenerateCodeAttribute"));
    var userType = CodeGenPolicy.GetStringProp(genAttr, "BaseUserType");
    var namespaceName = Model.Namespace.Replace(".Models", ".Entities");
    var servicesNamespace = namespaceName.Replace(".Entities", ".Services");
}
using TKW.Framework.Domain;

namespace @(servicesNamespace);
/// <summary>@Raw(Model.Summary)Service</summary>
public partial class @(serviceName)(DomainUser<@(userType)> user, IFreeSql fsql) 
    : DomainServiceBase<@userType>(user)
{

}