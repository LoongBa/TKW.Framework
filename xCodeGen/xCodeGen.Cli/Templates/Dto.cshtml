@using System.Linq
@using xCodeGen.Abstractions
@using xCodeGen.Abstractions.Metadata
@using TKW.Framework.Domain.xCodeGen
@model ClassMetadata
@{
    var dtoClassName = Model.ClassName + "Dto";
    var generatedNs = Model.GenerateCodeSettings["GeneratedNamespace"].ToString();
    var metaHash = Model.GenerateCodeSettings.ContainsKey("MetadataHash") ? Model.GenerateCodeSettings["MetadataHash"]?.ToString() : "N/A";
    var timestamp = DateTime.Now.ToString("yyyy-MM-dd HH:mm:ss");
    
    Model.GenerateCodeSettings["Type"] = "Dto";

    var genAttr = Model.Attributes.FirstOrDefault(a => a.TypeFullName.Contains("GenerateCodeAttribute"));
    var customAutoFields = CodeGenPolicy.GetStringProp(genAttr, "CustomAutoFields")?.Split(',', StringSplitOptions.RemoveEmptyEntries);

    // 过滤掉 explicitly ignored properties
    var dtoProps = Model.Properties
        .Where(p => !p.Attributes.Any(a => a.TypeFullName.Contains("DtoFieldIgnore")))
        .Where(p => p.Name != "IsFromPersistentSource")
        .OrderBy(p => {
            var col = p.Attributes.FirstOrDefault(a => a.TypeFullName.Contains("ColumnAttribute"));
            return (col != null && col.Properties.TryGetValue("Position", out var pos) && pos is int i) ? i : 999;
        }).ToList();

    // 辅助：处理多行 Summary 格式安全
    string CleanSummary(string? sum) => string.IsNullOrWhiteSpace(sum) ? "" 
        : sum.Replace("\r", "").Replace("\n", " ").Replace("\"", "\\\"").Trim();
}
// <auto-generated>
// 此文件由 xCodeGen 自动生成，请勿手动修改。
// @@[xCodeGen.Hash: @metaHash]
// 模型: @Model.ClassName (@Model.FullName)
// 生成时间: @timestamp
// </auto-generated>
#nullable enable
using System;
using System.Linq;
using System.Collections.Generic;
using System.ComponentModel.DataAnnotations;
using xCodeGen.Abstractions;
using xCodeGen.Abstractions.Metadata;
using TKW.Framework.Domain;
using TKW.Framework.Domain.Interfaces;
using TKW.Framework.Domain.xCodeGen;
using TKW.Framework.Common.Exceptions;
using @Model.Namespace;

namespace @(Model.Namespace).DTOs;
/// <summary>@Raw(Model.Summary)</summary>
public partial record @dtoClassName : DomainDtoBase<@Model.ClassName>
{
    #region 属性定义
@foreach (var p in dtoProps)
{
    var dtoAttr = p.Attributes.FirstOrDefault(a => a.TypeFullName.Contains("DtoFieldAttribute"));
    bool isRequiredConfig = CodeGenPolicy.GetBoolProp(dtoAttr, "IsRequired", false) 
                      || p.Attributes.Any(a => a.TypeFullName.Contains("RequiredAttribute"));
    
    // C# 8.0+ Nullable 检查：仅对非空字符串或明确声明必填的属性附加 required，解决 CS8618
    bool isString = p.TypeName == "string" || p.TypeName == "System.String";
    string requiredModifier = (isRequiredConfig || (!p.IsNullable && isString)) ? "required " : "";

    @:/// <summary> @Raw(CleanSummary(p.Summary ?? p.Name)) </summary>
    @:public @Raw(requiredModifier)@Raw(p.TypeName) @(p.Name) { get; init; }
}
    #endregion

    #region [ 静态工厂 ]
    /// <summary> 从实体转换为 DTO </summary>
    public static @(dtoClassName) FromEntity(@(Model.ClassName) entity)
    {
        ArgumentNullException.ThrowIfNull(entity);
        return new @(dtoClassName)
        {
            IsFromPersistentSource = entity.IsFromPersistentSource,
@foreach (var p in dtoProps) {
            @:@(p.Name) = entity.@(p.Name),
}
        };
    }
    #endregion

    public override @Model.ClassName ApplyToEntity(@Model.ClassName entity, EnumSceneFlags scene = EnumSceneFlags.Update)
    {
        ArgumentNullException.ThrowIfNull(entity);
        this.CreateMapper(entity, scene)
@foreach (var p in dtoProps)
{
    // 1. 系统自动管理字段拦截
    if (CodeGenPolicy.IsAutoManaged(p, customAutoFields)) continue;

    // 2. 导航属性拦截：绝对禁止回填 [Navigate] 字段，防止引发 ORM 级联插入/更新污染
    bool isNavigate = p.Attributes.Any(a => a.TypeFullName.Contains("NavigateAttribute"));
    if (isNavigate) continue;

    // 3. 物理忽略拦截：禁止回填 [Column(IsIgnore = true)]
    var colAttr = p.Attributes.FirstOrDefault(a => a.TypeFullName.Contains("ColumnAttribute"));
    bool isColumnIgnore = colAttr != null && CodeGenPolicy.GetBoolProp(colAttr, "IsIgnore", false);
    if (isColumnIgnore) continue;

    var dtoAttr = p.Attributes.FirstOrDefault(a => a.TypeFullName.Contains("DtoFieldAttribute"));
    
    // 4. 只读拦截：禁止回填业务上标注不可修改的字段
    bool canModify = CodeGenPolicy.GetBoolProp(dtoAttr, "CanModify", true);
    if (!canModify) continue;

    // 5. Masking 智能逻辑
    bool hasMaskPattern = !string.IsNullOrEmpty(CodeGenPolicy.GetStringProp(dtoAttr, "MaskPattern"));
    bool isMaskingExplicitlyFalse = dtoAttr != null && dtoAttr.Properties.TryGetValue("Masking", out var mVal) && mVal is bool b && !b;
    bool isMasking = (CodeGenPolicy.GetBoolProp(dtoAttr, "Masking", false) || hasMaskPattern) && !isMaskingExplicitlyFalse;

    var maskParam = isMasking ? $", e => e.{p.Name}" : "";
@:            .Map(nameof(@p.Name), d => d.@p.Name, (e, v) => e.@p.Name = v @Raw(maskParam))
}
        ;
        return entity;
    }

    public override void ValidateData(EnumSceneFlags scene)
    {
        if (IsFromPersistentSource && (scene & EnumSceneFlags.ForceValidate) == 0) return;
        
        var results = ValidateDataCore(scene).ToList();
        OnCustomValidate(scene, results);
        if (results.Any()) throw new ValidationResultsException(results);
    }

    protected IEnumerable<ValidationResult> ValidateDataCore(EnumSceneFlags scene)
    {
        var results = new List<ValidationResult>();
        @{ await IncludeAsync("_InternalValidation.cshtml", Model); }
        return results;
    }

    partial void OnCustomValidate(EnumSceneFlags scene, List<ValidationResult> results);
}