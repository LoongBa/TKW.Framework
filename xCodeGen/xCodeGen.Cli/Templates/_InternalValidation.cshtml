@using xCodeGen.Abstractions.Metadata
@using TKW.Framework.Domain.xCodeGen
@model ClassMetadata
@{
    var generateType = Model.GenerateCodeSettings.ContainsKey("Type") 
            ? Model.GenerateCodeSettings["Type"].ToString() : "";
    bool isDto = generateType == "Dto";

    // 1. 直接通过 this 启动验证链条
    if (isDto) {
        @:this.CreateDtoValidator<@(Model.ClassName), @(Model.ClassName)Dto>(scene, results)
    } else {
        @:this.CreateModelValidator(scene, results)
    }

    // 2. 链式调用：保持 12 格缩进以对齐起始方法
    foreach (var p in Model.Properties)
    {
        var colAttr = p.Attributes.FirstOrDefault(a => a.TypeFullName.Contains("ColumnAttribute"));
        var dtoAttr = p.Attributes.FirstOrDefault(a => a.TypeFullName.Contains("DtoFieldAttribute"));
        
        if (p.Attributes.Any(a => a.TypeFullName.Contains("RequiredAttribute")) || CodeGenPolicy.GetBoolProp(dtoAttr, "IsRequired", false))
        {
            @:.Required(nameof(@p.Name), d => d.@p.Name)
        }

        if (colAttr != null && colAttr.Properties.TryGetValue("StringLength", out var slenObj) && slenObj is int slen && slen > 0)
        {
            @:.MaxLength(nameof(@p.Name), @slen, d => d.@p.Name)
        }
    }
        @:;
}