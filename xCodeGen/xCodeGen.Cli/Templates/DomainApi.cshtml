@using System.Linq
@using xCodeGen.Abstractions.Metadata
@inherits xCodeGen.Core.Templates.TemplatePageBase<IProjectMetaContext>
@model IProjectMetaContext
@{

    // 将控制器和领域服务合并，作为暴露给 Agent 的全量行为契约
    var apiComponents = Model.Controllers.Concat(Model.Services).GroupBy(m => m.SubDomain);
}
[//]: # ( <auto-generated> [xCodeGen.Hash: @(Model.Configuration.CustomProperties.ContainsKey("MetadataHash") ? Model.Configuration.CustomProperties["MetadataHash"] : "N/A")] </auto-generated> )

# 业务契约字典 (Domain API)

@foreach (var subDomain in apiComponents)
{
@:## 业务子域：@(subDomain.Key)
    
    @foreach (var comp in subDomain)
    {
        var interfaceMeta = comp.Interface;
        var displayName = interfaceMeta?.ClassName ?? "I" + comp.ClassName;
    
@:### 契约接口：@(displayName)
@:> @ToMdQuote(comp.Summary)
@:
@:| 方法签名 | 权限/事务约束 | 功能描述 |
@:| :--- | :--- | :--- |
    foreach (var m in comp.Methods.Where(m => m.AccessModifier == "public"))
    {
        var filters = string.Join(", ", m.Attributes.Select(a => $"[{a.Name}]"));
@:| @(m.Name) | @(filters) | @ToMd(m.Summary) |
    }
@:
    }
}