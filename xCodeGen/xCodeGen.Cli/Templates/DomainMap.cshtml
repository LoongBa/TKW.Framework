@using System.Linq
@using xCodeGen.Abstractions.Metadata
@inherits xCodeGen.Core.Templates.TemplatePageBase<IProjectMetaContext>
@model IProjectMetaContext
@{
    // 自动从上下文中提取底层的公理接口
    var dacMeta = Model.AllMetadatas.FirstOrDefault(m => m.ClassName == "IEntityDAC");
    var readOnlyDacMeta = Model.AllMetadatas.FirstOrDefault(m => m.ClassName == "IEntityReadOnlyDAC");
}
[//]: # ( <auto-generated> [xCodeGen.Hash: @(Model.Configuration.CustomProperties.ContainsKey("MetadataHash") ? Model.Configuration.CustomProperties["MetadataHash"] : "N/A")] </auto-generated> )

# 领域数据地图 (Domain Map)

> **公理声明**：本系统内所有标记为 `[DataService]` 的组件均自动具备底层标准能力。
> 读写实体具备 `IEntityDAC` 标准 CRUD 能力；只读视图仅具备 `IEntityReadOnlyDAC` 查询能力。下文仅列出各业务扩展特有的方法。

@if (dacMeta != null)
{
@:### 公共数据操作协议 (IEntityDAC)
foreach (var m in dacMeta.Methods)
{
@:- **@(m.Name)**: @ToMd(m.Summary)
}
}

@* 直接使用基类提供的 Entities 属性，无需再次 Where 过滤 *@
@foreach (var group in Model.Entities.GroupBy(m => m.SubDomain))
{
@:## 子域：@(group.Key)
    
    foreach (var entity in group)
    {
        var service = entity.Service;
@:### 实体：@(entity.ClassName)
@:> @ToMdQuote(entity.Summary)
        
@:#### DTO @(entity.ClassName)Dto 字段映射
@:| 属性名 | 类型 | 描述 |
@:| :--- | :--- | :--- |
        foreach (var prop in entity.Properties)
        {
@:| @(prop.Name) | `@(prop.TypeName)` | @ToMd(prop.Summary) |
        }

        // 仅在真的有手写 Custom 方法时，才渲染扩展能力大纲
        if (service != null && service.Methods.Any(m => m.Origin == MethodOrigin.Custom))
        {
@:#### 扩展数据能力 (Custom Methods)
            var customMethods = service.Methods.Where(m => m.Origin == MethodOrigin.Custom);
            foreach (var m in customMethods)
            {
@:- **@(m.Name)**: @ToMd(m.Summary) (源文件: @(m.SourceFile))
            }
        }
@:
    }
}