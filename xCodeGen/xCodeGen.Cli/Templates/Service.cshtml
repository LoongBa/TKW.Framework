    internal Task<@(className)> InternalGetAsync(Expression<Func<@(className), bool>> predicate, CancellationToken ct = default)
        => QueryForUser().Where(predicate).FirstAsync(ct);

    internal Task<List<@(className)>> InternalSelectAsync(Expression<Func<@(className), bool>> predicate, int skip, int limit, Func<ISelect<@(className)>, ISelect<@(className)>> orderBy, CancellationToken ct)
    {
        // 边界安全检查
        var safeSkip = Math.Max(0, skip);
        var safeLimit = Math.Clamp(limit, 1, CodeGenPolicy.DefaultLimit);

        var q = QueryForUser();
        if (predicate != null) q = q.Where(predicate);
        q = orderBy != null ? orderBy(q) : q.OrderByDescending(x => x.@pkName);
        return q.Skip(safeSkip).Limit(safeLimit).ToListAsync(ct);
    }

