    var genAttr = Model.Attributes.FirstOrDefault(a => a.TypeFullName.Contains("GenerateCodeAttribute"));
    var userType = CodeGenPolicy.GetStringProp(genAttr, "BaseUserType");
    bool isView = CodeGenPolicy.GetBoolProp(genAttr, "IsView", false);
    int defPageSize = genAttr != null && genAttr.Properties.TryGetValue("DefaultPageSize", out var ps) ? (int)ps : 20;
    int defLimit = genAttr != null && genAttr.Properties.TryGetValue("DefaultLimit", out var dl) ? (int)dl : 1000;
    int maxSearch = genAttr != null && genAttr.Properties.TryGetValue("MaxSearchLimit", out var ms) ? (int)ms : 500;
    var pkProp = Model.Properties.FirstOrDefault(p => 
        p.Attributes.Any(a => a.TypeFullName.Contains("ColumnAttribute") && CodeGenPolicy.GetBoolProp(a, "IsPrimary", false))) 
        ??
        Model.Properties.FirstOrDefault(p => p.Name == "Id");
    
    var pkName = pkProp?.Name ?? "Id";
    var pkType = pkProp?.TypeName ?? "long";
    var hasIsDeleted = Model.Properties.Any(p => p.Name == "IsDeleted");
    var searchGroups = CodeGenPolicy.GetSearchGroups(Model);

    var metaHash = Model.GenerateCodeSettings.ContainsKey("MetadataHash") ? Model.GenerateCodeSettings["MetadataHash"]?.ToString() : "N/A";
    var timestamp = DateTime.Now.ToString("yyyy-MM-dd HH:mm:ss");
}
