{
  "TargetProject": "..\\DMP-Lite.Domain.csproj",
  "EnableSkipUnchanged": true,
  "OutputRoot": "Generated",
  "EnableInterfaceExtraction": true,
  "InterfaceOutputPath": "..\\..\\Interfaces",
  "ServiceDirectory": "..\\..\\Services",

  "TemplatesPath": "Templates",
  "TemplateMappings": {
    "Service": "Service.cshtml",
    "Entity": "Entity.cshtml",
    "Dto": "Dto.cshtml"
  },
  "SkeletonMappings": {
    "EntityEmpty": "EntityEmpty.cshtml",
    "DtoEmpty": "DtoEmpty.cshtml",
    "ServiceEmpty": "ServiceEmpty.cshtml"
  },
  "FileNamePatterns": {
    "Service": "{ClassName}Service.g.cs",
    "ServiceEmpty": "{ClassName}Service.cs",
    "EntityEmpty": "{ClassName}.biz.cs",
    "Entity": "{ClassName}.g.cs",
    "DtoEmpty": "{ClassName}Dto.cs",
    "Dto": "{ClassName}Dto.g.cs"
  },
  "OutputDirectories": {
    "EntityEmpty": "..\\..\\Entities",
    "Entity": "..\\..\\Entities",
    "DtoEmpty": "..\\..\\Entities\\DTOs",
    "Dto": "..\\..\\Entities\\DTOs",
    "Service": "..\\..\\Services",
    "ServiceEmpty": "..\\..\\Services"
  },
  "CustomSettings": {
    "EnableLogging": "true",
    "AutoManagedFields": "Id,CreateTime,UpdateTime,IsDeleted,TenantId,UId"
  }
}