{
  "TargetProject": "..\\DMP-Lite.Domain.csproj",
  "EnableSkipUnchanged": true,
  "OutputRoot": "Generated",
  "EnableInterfaceExtraction": false,
  "InterfaceOutputPath": "..\\..\\Interfaces",
  "ServiceDirectory": "..\\..\\Services",
  "TemplatesPath": "Templates",

  "Artifacts": {
    "Entity": {
      "Scope": "Entity",
      "Template": "Entity.cshtml",
      "OutputPattern": "{ClassName}.g.cs",
      "OutputDir": "..\\..\\Entities",
      "SkeletonTemplate": "EntityEmpty.cshtml",
      "SkeletonPattern": "{ClassName}.biz.cs",
      "SkeletonDir": "..\\..\\Entities"
    },
    "Dto": {
      "Scope": "Entity",
      "Template": "Dto.cshtml",
      "OutputPattern": "{ClassName}Dto.g.cs",
      "OutputDir": "..\\..\\Entities\\DTOs",
      "SkeletonTemplate": "DtoEmpty.cshtml",
      "SkeletonPattern": "{ClassName}Dto.cs",
      "SkeletonDir": "..\\..\\Entities\\DTOs"
    },
    "DataService": {
      "Scope": "Entity",
      "Template": "DataService.cshtml",
      "OutputPattern": "{ClassName}DataService.g.cs",
      "OutputDir": "..\\..\\DataServices",
      "SkeletonTemplate": "DataServiceEmpty.cshtml",
      "SkeletonPattern": "{ClassName}DataService.cs",
      "SkeletonDir": "..\\..\\DataServices"
    },
    "DomainMap": {
      "Scope": "Project",
      "Template": "DomainMap.cshtml",
      "OutputPattern": "DomainMap.g.cs",
      "OutputDir": "..\\..\\docs\\AgencyMD"
    },
    "DomainDNA": {
      "Scope": "Project",
      "OutputPattern": "DomainDNA.g.cs",
      "OutputDir": "..\\..\\docs\\AgencyMD",
      "SkeletonTemplate": "DomainDNA.cshtml"
    },
    "Domain_Log": {
      "Scope": "Project",
      "OutputPattern": "Domain_Log.g.cs",
      "OutputDir": "..\\..\\docs\\AgencyMD",
      "SkeletonTemplate": "Domain_Log.cshtml"
    }
  },

  "CustomSettings": {
    "EnableLogging": "true",
    "AutoManagedFields": "Id,CreateTime,UpdateTime,IsDeleted,TenantId,UId"
  }
}